# O app NÃO precisa de chaves de API em variável de ambiente — elas ficam
# cifradas no navegador (react-secure-storage) e vão ao servidor a cada request.
# Todas as variáveis abaixo são opcionais.

# Ollama (local, sem chave) — requer "ollama serve" rodando
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=all-minilm

# Provider de embedding do índice (gemini | openai | ollama). Default: gemini.
# NIXA_EMBEDDING_PROVIDER=gemini
