# Gemini (opcional) — fallback compartilhado do site: visitantes que não
# configurarem a própria chave usam esta. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (opcional) — mesmo papel de fallback compartilhado
# OPENAI_API_KEY=

# Ollama (local, sem chave) — requer "ollama serve" rodando
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=all-minilm
