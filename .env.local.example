# Obtenha grátis em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LanceDB Cloud
LANCEDB_URI=db://your-db-name
LANCEDB_API_KEY=sk_your_key_here
LANCEDB_REGION=us-east-1

# Modo de tier — controla modelo de embedding, concorrência e armazenamento de vetores
# FREE_TIER=true  → storage local (JSON), modelos menores, throughput conservador
# FREE_TIER=false → LanceDB Cloud, modelos maiores, throughput maior
# AVISO: trocar FREE_TIER com vectorstore existente exige re-indexação completa
FREE_TIER=true

# Criptografia das chaves salvas no modal de configuracao (obrigatorio)
LLM_SETTINGS_MASTER_KEY=uma-chave-forte-e-unica

# ─── Modelos de Embedding por tier ───────────────────────────────────────────
# Os defaults abaixo são selecionados automaticamente pelo FREE_TIER.
# Defina aqui para sobrescrever o default do tier.
#
# Gemini:
#   free  → text-embedding-004    (768 dims)
#   paid  → gemini-embedding-001  (3072 dims)
# GEMINI_EMBEDDING_MODEL=text-embedding-004
#
# OpenAI:
#   free  → text-embedding-3-small  (1536 dims)
#   paid  → text-embedding-3-large  (3072 dims)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# Hugging Face:
#   free  → sentence-transformers/all-MiniLM-L6-v2  (384 dims)
#   paid  → BAAI/bge-large-en-v1.5                  (1024 dims)
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Opcional: Hugging Face API Key
# Obtenha em: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=microsoft/Phi-3-mini-4k-instruct
