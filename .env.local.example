# ─── Obrigatório ────────────────────────────────────────────────────────────
# Chave mestra para criptografar API keys no servidor (AES-256-GCM).
# Pode ser qualquer string longa e secreta.
LLM_SETTINGS_MASTER_KEY=troque-isso-por-uma-string-longa-e-secreta

# ─── Gemini (recomendado — gratuito) ────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Opcionais — outros providers ───────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# HUGGINGFACE_API_KEY=

# ─── Ollama (local, sem chave) ──────────────────────────────────────────────
# Rode "ollama serve" em outro terminal antes de usar.
# Defaults configurados pra Mac 8GB:
#   - llama3.2:1b   (1.3GB)   → chat leve, OK em PT-BR
#   - all-minilm    (46MB)    → embeddings ultra-leves
#
# Alternativas mais pesadas/melhores:
#   - llama3.1            (4.7GB)
#   - qwen2.5:7b          (4.4GB)
#   - nomic-embed-text    (274MB embeddings, 768-dim, mais qualidade)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=all-minilm
