# Chave mestra para criptografar API keys no servidor (AES-256-GCM)
LLM_SETTINGS_MASTER_KEY=troque-isso-por-uma-string-longa-e-secreta

# Gemini (recomendado — gratuito): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (opcional)
# OPENAI_API_KEY=

# Ollama (local, sem chave) — requer "ollama serve" rodando
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=all-minilm
